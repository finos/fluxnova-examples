    <bpmn:scriptTask id="Activity_1divg7x" name="Assign Business Key" scriptFormat="javascript">
      <bpmn:incoming>Flow_02da6ba</bpmn:incoming>
      <bpmn:outgoing>Flow_1c46vz9</bpmn:outgoing>
      <bpmn:script>execution.setProcessBusinessKey(java.util.UUID.randomUUID().toString())</bpmn:script>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Activity_09cunxj" name="Inject Business Key into Prompt" scriptFormat="javascript">
      <bpmn:incoming>Flow_1c46vz9</bpmn:incoming>
      <bpmn:outgoing>Flow_0kwbxxl</bpmn:outgoing>
      <bpmn:script>execution.setVariable("prompt", execution.getVariable("prompt").concat(" businessKey is ").concat(execution.getBusinessKey()))</bpmn:script>
    </bpmn:scriptTask>
  </bpmn:process>
