<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:fluxnova="http://fluxnova.finos.org/schema/1.0/bpmn" xmlns:modeler="http://fluxnova.finos.org/schema/modeler/1.0" id="Definitions_1p27ygz" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Fluxnova Modeler" exporterVersion="1.1.1-dev" modeler:executionPlatform="Fluxnova Platform" modeler:executionPlatformVersion="1.0.0">
  <bpmn:process id="process-fee-waiver-request" name="Process Fee Waiver Request" isExecutable="true" camunda:historyTimeToLive="30">
    <bpmn:startEvent id="start-event" name="Fee Waiver Request Processing Required">
      <bpmn:outgoing>Flow_1krz2y0</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="svc-analyze-case" name="LLM Case Analysis" camunda:asyncBefore="true" camunda:delegateExpression="${llmCaseAnalysisDelegate}">
      <bpmn:incoming>Flow_1krz2y0</bpmn:incoming>
      <bpmn:outgoing>Flow_11d0ro1</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1krz2y0" sourceRef="start-event" targetRef="svc-analyze-case" />
    <bpmn:exclusiveGateway id="gw-policy-route" name="Policy Route?">
      <bpmn:incoming>Flow_0d9su7m</bpmn:incoming>
      <bpmn:outgoing>Flow_0dchcmq</bpmn:outgoing>
      <bpmn:outgoing>Flow_1ru6m9x</bpmn:outgoing>
      <bpmn:outgoing>Flow_14wf3k0</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_11d0ro1" sourceRef="svc-analyze-case" targetRef="svc-apply-guardrail" />
    <bpmn:endEvent id="end-event-autoapprove" name="Fee Waiver Request Automatically Approved">
      <bpmn:incoming>Flow_0dchcmq</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0dchcmq" name="Auto Approved" sourceRef="gw-policy-route" targetRef="end-event-autoapprove">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${policyRoute == "AUTO_PROCESS"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="end-event-escalated" name="Fee Waiver Request Escalated">
      <bpmn:incoming>Flow_1ru6m9x</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1ru6m9x" name="Escalated" sourceRef="gw-policy-route" targetRef="end-event-escalated">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${policyRoute == "ESCALATE"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_14wf3k0" name="Human Review Required" sourceRef="gw-policy-route" targetRef="usr-review-case">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${policyRoute == "HUMAN_REVIEW"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:userTask id="usr-review-case" name="Review Case" camunda:asyncAfter="true" camunda:formKey="embedded:app:forms/review-case.html" camunda:assignee="demo">
      <bpmn:extensionElements>
        <camunda:taskListener event="complete" id="completeListener">
          <camunda:script scriptFormat="javascript">var reviewer = task.getAssignee();
task.getExecution().setVariable('reviewer', reviewer);

var taskDecision = task.getVariable('taskDecision');
var reviewDecision;
if(taskDecision)
  reviewDecision = "APPROVE";
else
  reviewDecision = "REJECT";

task.getExecution().setVariable('reviewDecision', reviewDecision);</camunda:script>
        </camunda:taskListener>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_14wf3k0</bpmn:incoming>
      <bpmn:outgoing>Flow_0fvum80</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_0fvum80" sourceRef="usr-review-case" targetRef="svc-submit-review" />
    <bpmn:serviceTask id="svc-submit-review" name="Submit Review" camunda:asyncBefore="true" camunda:delegateExpression="${submitReviewDelegate}">
      <bpmn:incoming>Flow_0fvum80</bpmn:incoming>
      <bpmn:outgoing>Flow_1nqgzxi</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end-event-manual-review" name="Fee Waiver Request Processed">
      <bpmn:incoming>Flow_1nqgzxi</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1nqgzxi" sourceRef="svc-submit-review" targetRef="end-event-manual-review" />
    <bpmn:subProcess id="Activity_1nm1zz5" triggeredByEvent="true">
      <bpmn:serviceTask id="svc-fee-waiver-history-tool" name="Fee Waiver History Tool Action" camunda:delegateExpression="${feeWaiverHistoryDelegate}">
        <bpmn:incoming>Flow_0jjorxc</bpmn:incoming>
        <bpmn:outgoing>Flow_0ffxbqz</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:sequenceFlow id="Flow_0jjorxc" sourceRef="start-ni-fee-waiver-history-tool" targetRef="svc-fee-waiver-history-tool" />
      <bpmn:endEvent id="end-fee-waiver-history-tool" name="Fee Waiver History Tool Completed">
        <bpmn:incoming>Flow_0ffxbqz</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_0ffxbqz" sourceRef="svc-fee-waiver-history-tool" targetRef="end-fee-waiver-history-tool" />
      <bpmn:startEvent id="start-ni-fee-waiver-history-tool" name="Fee Waiver History Tool Requested" isInterrupting="false">
        <bpmn:outgoing>Flow_0jjorxc</bpmn:outgoing>
        <bpmn:conditionalEventDefinition id="ConditionalEventDefinition_05w9ovm" camunda:variableName="toolConversationOccurred">
          <bpmn:condition xsi:type="bpmn:tFormalExpression">${toolConversationOccurred == true}</bpmn:condition>
        </bpmn:conditionalEventDefinition>
      </bpmn:startEvent>
    </bpmn:subProcess>
    <bpmn:sequenceFlow id="Flow_0d9su7m" sourceRef="svc-apply-guardrail" targetRef="gw-policy-route" />
    <bpmn:businessRuleTask id="svc-apply-guardrail" name="Apply Guardrail" camunda:delegateExpression="${finalGuardrailDelegate}">
      <bpmn:incoming>Flow_11d0ro1</bpmn:incoming>
      <bpmn:outgoing>Flow_0d9su7m</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:textAnnotation id="TextAnnotation_1k2034u">
      <bpmn:text>Required Inputs:

1) requestText
2) priorFeeWaiverCount
3) feeAmount
4) vulnerableCustomer
5) regulatorySensitivity</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1324rhv" associationDirection="None" sourceRef="start-event" targetRef="TextAnnotation_1k2034u" />
    <bpmn:textAnnotation id="TextAnnotation_0f9ouhu">
      <bpmn:text>Provided:

1) reviewDecision
2) reviewNotes</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_06qsrl4" associationDirection="None" sourceRef="usr-review-case" targetRef="TextAnnotation_0f9ouhu" />
    <bpmn:textAnnotation id="TextAnnotation_0ir3kmq">
      <bpmn:text>Returned:

1) entityId
2) policyRoute
3) finalAction
4) requiresHumanReview</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1yv8nk7" associationDirection="None" sourceRef="svc-analyze-case" targetRef="TextAnnotation_0ir3kmq" />
    <bpmn:textAnnotation id="TextAnnotation_1ntky5u">
      <bpmn:text>Contains embedded guardrails using rules (with Drools Expert).</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_02jdmny" associationDirection="None" sourceRef="svc-analyze-case" targetRef="TextAnnotation_1ntky5u" />
    <bpmn:textAnnotation id="TextAnnotation_0jmy265">
      <bpmn:text>Uses Drools Expert to apply a final guardrail before routing.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0aikqv2" associationDirection="None" sourceRef="svc-apply-guardrail" targetRef="TextAnnotation_0jmy265" />
  </bpmn:process>
  <bpmn:message id="Message_347e0v3" name="AI_TOOL_REQUESTED" />
